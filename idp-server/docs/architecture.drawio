                    <mxGeometry x="400" y="50" width="340" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="worker-dlq" value="DLQ Replay Tool&#10;- cmd/replay_audit_dlq&#10;- Manual Audit Recovery" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;" vertex="1" parent="layer-workers">
                    <mxGeometry x="20" y="170" width="340" height="70" as="geometry"/>
                </mxCell>

                <!-- ZONE: DATA PERSISTENCE -->
                <mxCell id="zone-data" value="Data Layer (Isolated Network)" style="swimlane;whiteSpace=wrap;html=1;startSize=23;fillColor=#ffe6cc;dashed=1;" vertex="1" parent="1">
                    <mxGeometry x="1460" y="40" width="360" height="1500" as="geometry"/>
                </mxCell>
                <mxCell id="db-mysql" value="MySQL Primary / Replicas&#10;[Entities &amp; Logs]&#10;- users / clients / roles&#10;- auth_codes / tokens&#10;- login_sessions (Persistence)&#10;- audit_events (History)&#10;- jwk_keys (Public Keys)" style="shape=datastore;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="zone-data">
