<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" type="device">
    <diagram id="architect-v7" name="Sienne IdP Full Technical Architecture">
        <mxGraphModel dx="2800" dy="2000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="1654" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                
                <!-- ZONE: CONFIGURATION & BOOTSTRAP -->
                <mxCell id="zone-boot" value="Boot and Configuration Tier" style="swimlane;whiteSpace=wrap;html=1;startSize=23;fillColor=#f5f5f5;" vertex="1" parent="1">
                    <mxGeometry x="620" y="-300" width="800" height="240" as="geometry"/>
                </mxCell>
                <mxCell id="boot-config" value="Config Loader (loadConfig)&#10;- Env Variables (ISSUER, TTL)&#10;- YAML Files (idp.docker.yaml)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="zone-boot">
                    <mxGeometry x="20" y="40" width="220" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="boot-wire" value="Composition Root: Wire.go&#10;- initializeApp()&#10;- Dependency Injection&#10;- Service Assembly" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="zone-boot">
                    <mxGeometry x="280" y="40" width="240" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="boot-adapters" value="Adapter Layer&#10;- jwtServiceAdapter&#10;- keyManagerAdapter&#10;- Port/Infrastructure Mapping" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="zone-boot">
                    <mxGeometry x="540" y="40" width="240" height="60" as="geometry"/>
                </mxCell>

                <!-- ZONE: PUBLIC INTERNET -->
                <mxCell id="zone-public" value="Public Network (Internet)" style="swimlane;whiteSpace=wrap;html=1;startSize=23;fillColor=#f5f5f5;dashed=1;" vertex="1" parent="1">
                    <mxGeometry x="40" y="40" width="280" height="1500" as="geometry"/>
                </mxCell>
                <mxCell id="actor-user" value="End User&#10;(Mobile App / Browser)" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;" vertex="1" parent="zone-public">
                    <mxGeometry x="40" y="100" width="30" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="actor-app-conf" value="Confidential Client&#10;(Web Server / Backend)" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;" vertex="1" parent="zone-public">
                    <mxGeometry x="150" y="100" width="30" height="60" as="geometry"/>
