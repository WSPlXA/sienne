                <mxCell id="svc-mfa" value="MFA State Machine&#10;(Bitmask-based)" style="rounded=0;whiteSpace=wrap;html=1;fontStyle=1;strokeWidth=2;" vertex="1" parent="layer-logic">
                    <mxGeometry x="310" y="190" width="160" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="svc-audit" value="Audit Stream Producer&#10;[XADD to &quot;idp:audit:stream&quot;]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="layer-logic">
                    <mxGeometry x="10" y="260" width="460" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="layer-domain" value="Domain Layer: Core Models&#10;[User, Client, Session, Token, Role, Audit, PasskeyCredential]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="layer-logic">
                    <mxGeometry x="10" y="330" width="460" height="70" as="geometry"/>
                </mxCell>

                <!-- Infrastructure Layer -->
                <mxCell id="layer-infra" value="Infrastructure Layer: Ports &amp; Adapters" style="swimlane;whiteSpace=wrap;html=1;startSize=23;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="zone-app">
