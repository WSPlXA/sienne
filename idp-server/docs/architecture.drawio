                <mxCell id="http-admin" value="Admin / Console Handlers&#10;- RBAC Usage / Bootstrap&#10;- User Management&#10;- Audit DLQ Replay" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=5;" vertex="1" parent="layer-http">
                    <mxGeometry x="10" y="390" width="220" height="100" as="geometry"/>
