                <mxCell id="infra-cache" value="High-Performance Storage Core&#10;- BITFIELD Packed Storage (State 32b | Ver 32b)&#10;- Redis Lua CAS (Optimistic Locking)&#10;- HMGet / Multi-GET Optimizations" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeWidth=2;fontStyle=1;" vertex="1" parent="layer-infra">
