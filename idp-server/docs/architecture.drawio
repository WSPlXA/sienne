                </mxCell>
                <mxCell id="db-redis" value="Redis Hot-State Engine&#10;[Cache &amp; Message Bus]&#10;- BITFIELD Session State&#10;- CAS Lua Logic&#10;- &quot;idp:audit:stream&quot;&#10;- Replay / CSRF Locks&#10;- Throttle / Rate Limit" style="shape=datastore;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;" vertex="1" parent="zone-data">
                    <mxGeometry x="50" y="500" width="260" height="280" as="geometry"/>
