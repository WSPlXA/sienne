                    <mxGeometry x="620" y="40" width="800" height="1500" as="geometry"/>
                </mxCell>
                
                <!-- HTTP Layer -->
                <mxCell id="layer-http" value="Interface Layer: HTTP / Gin Framework" style="swimlane;whiteSpace=wrap;html=1;startSize=23;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="zone-app">
