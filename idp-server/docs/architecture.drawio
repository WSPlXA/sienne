                </mxCell>
                <mxCell id="infra-plugins" value="Strategy Registries&#10;- Grant Strategy (Code, CC, Refresh, Device)&#10;- Authn Strategy (Password, FedOIDC, MFA)&#10;- ClientAuth Strategy (Basic, Post, None, JWT)" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=5;" vertex="1" parent="layer-infra">
