                    <mxGeometry x="10" y="170" width="220" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="http-ui" value="UI / Interaction Handlers&#10;- Login (Multi-Auth)&#10;- Consent Management&#10;- MFA Setup / Verify&#10;- Device Flow UI" style="rounded=0;whiteSpace=wrap;html=1;align=left;spacingLeft=5;" vertex="1" parent="layer-http">
