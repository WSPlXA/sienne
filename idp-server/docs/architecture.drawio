                <mxCell id="http-middleware-stack" value="Middleware Chain:&#10;1. Recovery / Logger&#10;2. Rate Limiting&#10;3. CSRF Protection&#10;4. Session Context&#10;5. Admin Auth (32-bit RBAC)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=5;" vertex="1" parent="layer-http">
