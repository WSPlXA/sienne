                    <mxGeometry x="20" y="1040" width="760" height="420" as="geometry"/>
                </mxCell>
                <mxCell id="worker-audit" value="Audit Stream Consumer&#10;- Group: &quot;audit_group&quot;&#10;- Action: Batch SQL Insert&#10;- Error: Push to &quot;idp:audit:dlq&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeWidth=2;" vertex="1" parent="layer-workers">
                    <mxGeometry x="20" y="50" width="340" height="100" as="geometry"/>
