# =========================
# Base runtime
# =========================
IDP_SERVER_IMAGE=ghcr.io/wsplxa/sienne-idp-server:latest
IDP_HTTP_PORT=80
IDP_APP_ENV=prod

# =========================
# MySQL (primary)
# =========================
IDP_MYSQL_ROOT_PASSWORD=ChangeThisRootPassword_32CharsMin
IDP_MYSQL_ROOT_HOST=%
IDP_MYSQL_DATABASE=app
IDP_MYSQL_USER=app
IDP_MYSQL_PASSWORD=ChangeThisAppPassword_32CharsMin
IDP_MYSQL_PUBLISH=127.0.0.1:13306

# Optional full DSN override for primary.
# When set, server uses this instead of MYSQL_HOST/MYSQL_PORT/MYSQL_DATABASE/MYSQL_USER/MYSQL_PASSWORD.
IDP_MYSQL_DSN=

# =========================
# MySQL read path (off by default)
# =========================
# Keep empty in single-db mode.
# In replication profile, set it to db-replica.
IDP_MYSQL_READ_DSN=
IDP_MYSQL_STRONG_READ_SESSION_BY_ID=false
IDP_MYSQL_STRONG_READ_TOKEN_BY_SHA256=false

# =========================
# Replication profile only
# =========================
IDP_MYSQL_REPLICA_PUBLISH=127.0.0.1:23306
IDP_MYSQL_REPL_USER=repl
IDP_MYSQL_REPL_HOST=%
# IMPORTANT: must be <= 32 bytes, or CHANGE REPLICATION SOURCE fails with ERROR 3056.
IDP_MYSQL_REPL_PASSWORD=ChangeThisReplPassword_32Chars
IDP_MYSQL_READ_USER=idp_ro
IDP_MYSQL_READ_HOST=%
IDP_MYSQL_READ_PASSWORD=ChangeThisReplicaReadPassword32

# Example read DSN for replication profile:
# IDP_MYSQL_READ_DSN=idp_ro:ChangeThisReplicaReadPassword32@tcp(db-replica:3306)/app?parseTime=true&charset=utf8mb4&collation=utf8mb4_unicode_ci

# =========================
# Redis
# =========================
IDP_REDIS_PUBLISH=127.0.0.1:16379

# =========================
# IDP behavior
# =========================
IDP_FORCE_MFA_ENROLLMENT=true
IDP_SESSION_TTL=8h
IDP_ISSUER=https://idpsienne.uk
IDP_TOTP_ISSUER=IDP Sienne
IDP_PASSKEY_ENABLED=true
IDP_PASSKEY_RP_ID=idpsienne.uk
IDP_PASSKEY_RP_ORIGINS=https://idpsienne.uk
IDP_TOTP_SECRET_ENCRYPTION_KEY=AReplaceWithYour32+CharSecretKey
IDP_SIGNING_KEY_DIR=/var/lib/idp/keys
IDP_SIGNING_KEY_CHECK_INTERVAL=1h
IDP_SIGNING_KEY_ROTATE_BEFORE=24h
IDP_SIGNING_KEY_RETIRE_AFTER=24h

# =========================
# Federated OIDC (Google)
# =========================
IDP_FEDERATED_OIDC_PROVIDER_NAME=Google
IDP_FEDERATED_OIDC_ISSUER=https://accounts.google.com
IDP_FEDERATED_OIDC_CLIENT_ID=1081803056418-us145nst3kc1tvrsv9tmpmq5cb90gi2n.apps.googleusercontent.com
IDP_FEDERATED_OIDC_CLIENT_SECRET=
IDP_FEDERATED_OIDC_REDIRECT_URI=https://idpsienne.uk/login
IDP_FEDERATED_OIDC_CLIENT_AUTH_METHOD=client_secret_post
IDP_FEDERATED_OIDC_USERNAME_CLAIM=email
